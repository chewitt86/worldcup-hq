# Optional dev image: Node + Claude Code + the docker CLI, for tweaking the app AND
# managing the container from inside Claude Code.
#
# Build:  docker build -f Dockerfile.dev -t wc-dev .
# Run  :  docker run -it --rm \
#           -v /mnt/user/appdata/worldcup-hq:/app \
#           -v /var/run/docker.sock:/var/run/docker.sock \
#           -e ANTHROPIC_API_KEY=sk-ant-... \
#           wc-dev claude
#
# The docker.sock mount lets Claude Code run ./manage.sh (restart/rebuild/update).
# SECURITY: socket access = full control of Docker on the host. Only mount it if you're
# comfortable letting the agent manage containers, and review changes before applying.
FROM node:22-alpine
RUN apk add --no-cache git docker-cli docker-cli-compose \
 && npm install -g @anthropic-ai/claude-code
WORKDIR /app
CMD ["claude"]
