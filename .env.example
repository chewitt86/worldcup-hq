# Copy this to ".env" (which is git-ignored). docker compose reads it automatically.

# The in-app Admin login (tap the ⚙️ cog, then "GROWN-UPS ONLY"). CHANGE THIS.
ADMIN_PASSWORD=please-change-me

# Optional: a single shared password to gate the WHOLE site for viewers.
# Leave blank for an open site (fine on a private home LAN).
VIEW_PASSWORD=

# API keys are NOT set here — add them in the Admin panel (Match data & API keys).
# They are stored server-side in server/data/admin.json (shown masked, never sent
# to browsers) and persist via the bind-mounted server/data volume.

# Optional: expose the site on your own domain via a Cloudflare Tunnel (free HTTPS,
# no router port-forwarding). Paste the tunnel token from Cloudflare Zero Trust and
# uncomment BOTH lines — the second one switches the cloudflared container on.
# CLOUDFLARE_TUNNEL_TOKEN=
# COMPOSE_PROFILES=tunnel
